# =============================================================================
# Tycoon Backend — Environment Variables
# Copy this file to .env and fill in the values.
# Variables marked REQUIRED have no safe default and MUST be set in production.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
# NODE_ENV: development | staging | production | provision | test
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_DEFAULT_VERSION=1
API_ENABLE_LEGACY_UNVERSIONED=true
API_LEGACY_UNVERSIONED_SUNSET=          # ISO date, optional
CORS_ORIGIN=http://localhost:3000
ENABLE_SWAGGER=false                    # set true only in non-prod

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=tycoon_db
# DB_SYNCHRONIZE: NEVER true in production — use versioned migrations only.
DB_SYNCHRONIZE=false
DB_LOGGING=false

# ── JWT  (REQUIRED in production) ─────────────────────────────────────────────
# JWT_SECRET must be ≥ 32 characters in production. App refuses to start without it.
JWT_SECRET=                             # REQUIRED in prod — generate with: openssl rand -hex 32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                         # leave blank if no auth
REDIS_DB=0
REDIS_TTL=300

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL: error | warn | info | http | verbose | debug | silly
# Defaults: debug (development), info (production), error (test)
LOG_LEVEL=debug
# LOG_CONSOLE: enable stdout logging in production containers
LOG_CONSOLE=false

# ── Payment / Webhooks  (REQUIRED in production) ──────────────────────────────
# PAYMENT_WEBHOOK_SECRET must be ≥ 16 characters in production.
PAYMENT_WEBHOOK_SECRET=                 # REQUIRED in prod — set in your payment provider dashboard

# ── Ledger Reconciliation ─────────────────────────────────────────────────────
# Force dry-run mode regardless of NODE_ENV (useful in staging CI)
RECONCILIATION_DRY_RUN=false

# ── Data Export (Privacy module) ──────────────────────────────────────────────
DATA_EXPORT_DIR=./storage/data-exports
DATA_EXPORT_TTL_HOURS=24

# ── Game Defaults ─────────────────────────────────────────────────────────────
DEFAULT_AUCTION=true
DEFAULT_RENT_IN_PRISON=false
DEFAULT_MORTGAGE=true
DEFAULT_EVEN_BUILD=true
DEFAULT_RANDOMIZE_PLAY_ORDER=true
DEFAULT_STARTING_CASH=1500
